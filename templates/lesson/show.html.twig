{% extends 'base.html.twig' %}

{% block title %}{{ lesson.name }}{% endblock %}
{% block meta_description %}Page de la leçon {{lesson.name}} {% endblock %}

{% block body %}
<div class="lesson-div">

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">
            {{ message }}
        </div>
    {% endfor %}

    <div class="lesson-title">
        <h1> lecon : {{ lesson.name }}</h1>
    </div>
    <div class="lesson-sheet">
        <div>
            <h2> Fiche de la lecon "{{ lesson.name }}"</h2>
        </div>
        {% if lesson.getContent()%}
        <div class="lesson-explication">
            {{ lesson.content|raw }}
        </div>
        {% else %}
                <p>Cette leçon ne possède pas encore de contenu</p>
            {% endif %}

        {% if lesson.getVideoUrl() %}
        <div class="video-container">
            <div>
                <h2>Vidéo de la leçon</h2>
            </div>
                <video controls width="100%">
                    <source src= "{{ asset(lesson.getVideoUrl()) }}" type="video/mp4">
                Votre navigateur ne supporte pas la lecture vidéo.
                </video>
            </div>
            {% else %}
                <p>Cette leçon ne contient pas de vidéo.</p>
            {% endif %}
    </div>
    <div class="finish-lesson-div">
        {% if is_granted('ROLE_USER') %}
            {% if isValidated %}
                <button class="btn btn-success" disabled>Leçon déjà validée</button>
            {% else %}
                <a href="{{ path('app_lesson_validate', { id: lesson.id }) }}" class="btn btn-primary">Terminer la leçon</a>
            {% endif %}
        {% endif %}
    </div>
    </div>
        <button onclick="history.go(-1);" class="back-button">Retour à la page formation</button>
    </div>
</div>
{% endblock %}