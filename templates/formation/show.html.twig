{% extends 'base.html.twig' %}

{% block title %}Détails de la Formation{% endblock %}
{% block meta_description %}Page affichant le détail de la formation {{formation.name}} {% endblock %}

{% block body %}
<div>
    <div class="div-formation-name">
        <h1>{{ formation.name }}</h1>
    </div>
<div class="courses-grid">
    {% for course in courses %}
        <div class="course-card">

            <div class="course-header">
                <h3>{{ course.name }}</h3>
                <p class="course-price">{{ course.price }} €</p>
            </div>

            <div class="course-action">
                {% set accessKey = 'course_' ~ course.id %}
                {% if is_granted('ROLE_USER') and app.user.isActive %}
                    {% if accessMap[accessKey] is defined and accessMap[accessKey] %}
                        <a href="{{ path('app_course_access', {id: course.id}) }}" class="btn-access-course">
                            Accéder
                        </a>
                    {% else %}
                        <a href="{{ path('app_stripe_checkout', {type: 'course', id: course.id}) }}" class="btn-buy">
                            Acheter
                        </a>
                    {% endif %}
                {% else %}
                    <p class="info-text">Connexion requise</p>
                {% endif %}
            </div>

            <div class="lessons">
                <h4>Leçons</h4>

                {% for lesson in course.lessons %}
                    <div class="lesson-card">
                        <span>{{ lesson.name }}</span>
                        <span class="lesson-price">{{ lesson.price }} €</span>

                        {% set accessKey = 'lesson_' ~ lesson.id %}
                        {% if is_granted('ROLE_USER') and app.user.isActive %}
                            {% if accessMap[accessKey] is defined and accessMap[accessKey] %}
                                <a href="{{ path('app_lesson_access', {id: lesson.id}) }}" class="btn-access-lesson">Voir</a>
                            {% else %}
                                <a href="{{ path('app_stripe_checkout', {type: 'lesson', id: lesson.id}) }}" class="btn-buy-small">Acheter</a>
                            {% endif %}
                        {% endif %}
                    </div>
                {% endfor %}

            </div>

        </div>
    {% endfor %}
    </div>
</div>
{% endblock %}
